# Secrets & credentials
*.key
*.pem
.env
.env.*
credentials.json
token.json

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Model artifacts (fetched at install time by scripts/setup_env.sh; not committed)
talkybuddy/models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/
talkybuddy/models/_sherpa_cache/
# Large model binaries — LLM (qwen .gguf) and piper TTS voices (.onnx)
talkybuddy/models/*.gguf
talkybuddy/models/*.onnx
# A1 wake assets — Porcupine params/keyword models (fetched at verify time, not committed)
talkybuddy/web/assets/*.pv
talkybuddy/web/assets/*.ppn
.gstack/

# Runtime SQLite DB — seeded fresh on boot via seed_demo(); never commit demo state
talkybuddy/data/*.db
# Runtime logs (server / verify / rehearsal); keep setup.log as install record
talkybuddy/logs/*.log
!talkybuddy/logs/setup.log
